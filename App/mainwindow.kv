MDBoxLayout:
    orientation: 'vertical'

    MDToolbar:
        title: "Our Top Toolbar"
        left_action_items: [["menu"]]
        right_action_items: [["dots-vertical"]]

    MDLabel:
        id: my_label
        text: "Some Stuff"
        halign: "center"

    MDBottomAppBar:
        MDToolbar:
            icon: 'git'
            type: 'bottom'
            mode: "free-end"