#: import FadeTransition kivy.uix.screenmanager.FadeTransition
<Opening_Screen>:
    MDFloatLayout:
        MDLabel:
            id: opening_label
            text: "Welcome to SnapScore"
            size_hint: (.2,.1)
            pos_hint: {'x':.45,'y':.5}

        MDRectangleFlatButton:
            text: "Press to Continue"
            theme_text_color: "Custom"
            text_color: "black"
            line_color: "red"
            size_hint: (.1,.1)
            pos_hint: {'x':.45,'y':.25}
            on_release:
                root.manager.transition = FadeTransition(clearcolor=(0,0,0,0))
                root.manager.duration = 2
                root.manager.current = 'mscreen'

<Main_Screen>:
    MDBoxLayout:
        orientation: 'vertical'

        MDTopAppBar:
            title: "SnapScore"

        MDLabel:
            id: my_label
            text: "Test"
            halign: "center"